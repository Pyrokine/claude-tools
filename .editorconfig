# EditorConfig: https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,tsx,js,jsx,cjs,mjs,css,scss,json,html,md,yaml,yml}]
indent_style = space
indent_size = 4

[*.rs]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
