{
    "name": "@pyrokine/mcp-chrome",
    "version": "2.3.0",
    "description": "Chrome browser automation MCP Server using Chrome DevTools Protocol",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsc -w",
        "prepare": "npm run build",
        "lint": "eslint \"src/**/*.ts\" \"extension/src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" \"extension/src/**/*.ts\" --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "keywords": [
        "mcp",
        "browser",
        "automation",
        "cdp",
        "chrome",
        "puppeteer"
    ],
    "author": "Pyrokine",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ws": "^8.21.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.3",
        "@types/ws": "^8.18.1",
        "eslint": "^10.5.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "engines": {
        "node": ">=18"
    },
    "bin": {
        "mcp-chrome": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md",
        "README_zh.md",
        "LICENSE"
    ]
}
