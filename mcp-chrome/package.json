{
    "name": "@pyrokine/mcp-chrome",
    "version": "2.0.0",
    "description": "Chrome browser automation MCP Server using Chrome DevTools Protocol",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsc -w",
        "prepare": "npm run build",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "keywords": [
        "mcp",
        "browser",
        "automation",
        "cdp",
        "chrome",
        "puppeteer"
    ],
    "author": "Pyrokine",
    "license": "MIT",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ws": "^8.19.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^22.0.0",
        "@types/ws": "^8.18.1",
        "eslint": "9.26.0",
        "prettier": "^3.8.3",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.59.0"
    },
    "engines": {
        "node": ">=18"
    },
    "bin": {
        "mcp-chrome": "./dist/index.js"
    },
    "files": [
        "dist"
    ]
}
