{
    "name": "@pyrokine/mcp-ssh",
    "version": "2.4.0",
    "description": "A comprehensive SSH MCP Server for Claude Code",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "mcp-ssh": "dist/index.js"
    },
    "scripts": {
        "build": "node node_modules/typescript7/bin/tsc",
        "start": "node dist/index.js",
        "dev": "node node_modules/typescript7/bin/tsc && node dist/index.js",
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "prepublishOnly": "npm run build",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "test": "npm run build && node test/run-tests.mjs",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "keywords": [
        "mcp",
        "ssh",
        "claude",
        "remote",
        "automation"
    ],
    "author": "pyro",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Pyrokine/claude-tools.git"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@xterm/headless": "^6.0.0",
        "ssh2": "^1.17.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^26.1.1",
        "@types/ssh2": "^1.15.5",
        "eslint": "^10.7.0",
        "prettier": "^3.9.5",
        "typescript": "npm:@typescript/typescript6@^6.0.2",
        "typescript-eslint": "^8.64.0",
        "typescript7": "npm:typescript@^7.0.2"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "files": [
        "dist",
        "README.md",
        "README_zh.md",
        "LICENSE"
    ]
}
