{
    "name": "@pyrokine/mcp-ssh",
    "version": "2.0.2",
    "description": "A comprehensive SSH MCP Server for Claude Code",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "mcp-ssh": "dist/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsc && node dist/index.js",
        "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "prepublishOnly": "npm run build",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/"
    },
    "keywords": [
        "mcp",
        "ssh",
        "claude",
        "remote",
        "automation"
    ],
    "author": "pyro",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Pyrokine/claude-tools.git"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@xterm/headless": "^6.0.0",
        "ssh2": "^1.17.0",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^25.0.9",
        "@types/ssh2": "^1.15.5",
        "eslint": "9.26.0",
        "prettier": "^3.8.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "dist",
        "README.md",
        "README_zh.md",
        "LICENSE"
    ]
}
